# Git LFS — track large model artifacts only.
# Datasets (*.csv, *.parquet, *.data) are stored as raw bytes so the slug-pattern
# URL on raw.githubusercontent.com serves them directly. Customer-data uses the
# original full LFS rule set in 000-smb-consulting-customer-data/.gitattributes.
*.pkl filter=lfs diff=lfs merge=lfs -text
*.joblib filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.keras filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
